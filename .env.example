# ============================================================
# Exam Academy — Environment Variables
# Copy file này thành .env.local rồi điền vào
# ============================================================

# ─── PostgreSQL (bắt buộc) ───────────────────────────────────
# Local:  postgresql://postgres:password@localhost:5432/exam_academy
# Neon:   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/exam_academy

# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-here
JWT_EXPIRES_IN=7d

# ─── Gemini AI (bắt buộc để sinh câu hỏi) ───────────────────
# Lấy tại: https://aistudio.google.com/app/apikey  (miễn phí)
# Model:   gemini-2.0-flash (nhanh, free tier: 15 RPM / 1M TPD)
GEMINI_API_KEY=your-gemini-api-key-here

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
